{
  "manifest_version": 3,
  "name": "Samsara Show Numbers (DOM)",
  "version": "0.1.0",
  "description": "Labels visible interactive webpage elements with numbers for Samsara voice selection. Talks only to a Samsara process running on this same machine (loopback WebSocket).",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Samsara Show Numbers"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-core.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["http://127.0.0.1/*"]
}
